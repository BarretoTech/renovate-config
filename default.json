{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate configuration for the BarretoTech organization.",
  "extends": [
    "config:best-practices",
    "security:openssf-scorecard",
    ":automergeRequireAllStatusChecks",
    ":approveMajorUpdates",
    ":rebaseStalePrs",
    ":enableVulnerabilityAlerts",
    ":timezone(Europe/Oslo)"
  ],
  "schedule": [
    "* 0-5 25-31 * 0"
  ],
  "automergeSchedule": [
    "* 0-5 25-31 * 0"
  ],
  "semanticCommits": "enabled",
  "osvVulnerabilityAlerts": true,
  "prConcurrentLimit": 20,
  "prHourlyLimit": 0,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "configMigration": true,
  "reviewersFromCodeOwners": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group Bun runtime (.prototools, workflow bun-version) and @types/bun together",
      "groupName": "bun",
      "matchPackageNames": ["oven-sh/bun", "@types/bun", "bun"]
    },
    {
      "description": "Group .prototools toolchain updates (node, npm, gh) together",
      "groupName": "prototools toolchain",
      "matchPackageNames": ["node", "npm", "cli/cli"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Group all non-major devDependencies into a single PR per repo",
      "groupName": "devDependencies (non-major)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["!@types/bun"]
    },
    {
      "description": "Automerge non-major updates for linting, formatting, and type packages",
      "matchPackageNames": [
        "oxlint",
        "oxfmt",
        "prettier",
        "prettier-plugin-astro",
        "eslint",
        "@commitlint/{/,}**",
        "commitizen"
      ],
      "matchPackagePatterns": ["^@types/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Label and require review for major updates",
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"],
      "automerge": false
    },
    {
      "description": "Label security/vulnerability PRs and bypass the monthly schedule so fixes ship immediately",
      "matchCategories": ["security"],
      "addLabels": ["security"],
      "minimumReleaseAge": "0 days",
      "schedule": ["at any time"],
      "prPriority": 10
    },
    {
      "description": "Pin GitHub Actions to SHA digests for supply-chain security",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Group GitHub Actions updates (excluding bun, which groups with .prototools)",
      "matchManagers": ["github-actions"],
      "excludePackageNames": ["bun"],
      "groupName": "github-actions"
    },
    {
      "description": "Group docs site dependencies (Astro, Starlight, etc.)",
      "groupName": "docs dependencies",
      "matchFileNames": ["docs/package.json"],
      "separateMajorMinor": false
    }
  ]
}
